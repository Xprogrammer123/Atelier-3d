# Supabase — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (HTTPS in production — required for WebXR + OAuth redirects)
# Vercel: set to https://your-app.vercel.app or your custom domain
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel deployment — required or middleware returns MIDDLEWARE_INVOCATION_FAILED:
#   Project → Settings → Environment Variables → add ALL of the above for Production AND Preview
#   Then redeploy (env changes do not apply to past deployments)

# Google OAuth — configure in Supabase Dashboard (Authentication → Providers → Google)
# Add these in Supabase, NOT here, unless you use direct Google SDK:
#   Google Cloud Console → OAuth 2.0 Client ID
#   Authorized redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
# Also add to Supabase → Authentication → URL Configuration:
#   Site URL: http://localhost:3000  (or your production URL)
#   Redirect URLs: http://localhost:3000/auth/callback

# Blender path (optional — worker falls back to bundled script path)
BLENDER_PATH=blender
